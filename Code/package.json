  "type": "module",
  "description": "Suite de pruebas unitarias del sistema de reservas hotelero",
  "scripts": {
    "dev": "run-p dev:server dev:client",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
