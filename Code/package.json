{
  "name": "isw-213-examen",
  "version": "1.0.0",
  "description": "Proyecto ISW-213",
  "type": "commonjs",
  "scripts": {
    "dev:server": "nodemon --watch src --ext ts --exec \"ts-node --project tsconfig.server.json -r dotenv/config src/main.ts\"",
    "dev:frontend": "vite",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:frontend\"",
    "build:server": "tsc -p tsconfig.server.json --outDir dist-server",
    "build:frontend": "vite build",
    "build": "npm run build:server && npm run build:frontend",
    "start:server": "node dist-server/main.js",
    "start": "npm run start:server",
    "preview": "vite preview"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@types/express": "^5.0.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reflect-metadata": "^0.2.2",
    "ts-results": "^3.3.0",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^5.0.8"
  }
}
